# Copy this file to .env for local development. Do not commit real secrets.
PERSONAL_AGENT_ENVIRONMENT=development
PERSONAL_AGENT_DATABASE_URL=sqlite+aiosqlite:///./data/personal_agent.sqlite3
PERSONAL_AGENT_DATA_DIR=./data
PERSONAL_AGENT_POLICY_PATH=./config/policy.yaml
PERSONAL_AGENT_LOG_LEVEL=INFO

# Enable an integration only after configuring its required credential.
PERSONAL_AGENT_OPENAI__ENABLED=true
PERSONAL_AGENT_OPENAI__API_KEY=replace-me

PERSONAL_AGENT_TODOIST__ENABLED=false
PERSONAL_AGENT_TODOIST__API_TOKEN=

PERSONAL_AGENT_TELEGRAM__ENABLED=false
PERSONAL_AGENT_TELEGRAM__BOT_TOKEN=
# Pydantic Settings expects JSON for list-valued environment variables.
PERSONAL_AGENT_TELEGRAM__ALLOWED_CHAT_IDS=[]

PERSONAL_AGENT_MAC_WORKER__ENABLED=false
PERSONAL_AGENT_MAC_WORKER__SHARED_SECRET=
PERSONAL_AGENT_MAC_WORKER__WORKSPACE_ROOT=~/agent-workspaces
