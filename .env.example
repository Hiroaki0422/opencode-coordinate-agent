# Copy this file to .env for local development. Do not commit real secrets.
PERSONAL_AGENT_ENVIRONMENT=development
PERSONAL_AGENT_DATABASE_URL=sqlite+aiosqlite:///./data/personal_agent.sqlite3
PERSONAL_AGENT_DATA_DIR=./data
PERSONAL_AGENT_CHECKPOINT_PATH=./data/checkpoints.sqlite3
PERSONAL_AGENT_POLICY_PATH=./config/policy.yaml
PERSONAL_AGENT_LOG_LEVEL=INFO
PERSONAL_AGENT_LOG_FORMAT=console
PERSONAL_AGENT_LOG_REDACTED_FIELDS=[]
PERSONAL_AGENT_POLICY__SESSION_TTL_MINUTES=120
PERSONAL_AGENT_POLICY__APPROVAL_TTL_MINUTES=15

# Enable an integration only after configuring its required credential.
PERSONAL_AGENT_OPENAI__ENABLED=true
PERSONAL_AGENT_OPENAI__API_KEY=replace-me

PERSONAL_AGENT_DEEPSEEK__ENABLED=true
PERSONAL_AGENT_DEEPSEEK__API_KEY=replace-me

PERSONAL_AGENT_COORDINATOR__ENABLED=true
# Ordered fallback route. Add or replace providers without changing graph code.
PERSONAL_AGENT_COORDINATOR__MODELS='[{"provider":"openai","model":"gpt-5-mini"},{"provider":"deepseek","model":"deepseek-chat"}]'
# Codex subscription can be primary, fallback, or the only target:
# PERSONAL_AGENT_COORDINATOR__MODELS='[{"provider":"codex-subscription","model":"gpt-5.4"},{"provider":"openai","model":"gpt-5-mini"}]'

PERSONAL_AGENT_CODEX_SUBSCRIPTION__ENABLED=false
PERSONAL_AGENT_CODEX_SUBSCRIPTION__EXECUTABLE=codex
PERSONAL_AGENT_CODEX_SUBSCRIPTION__MODEL=gpt-5.4
# Use a dedicated login to avoid refresh-token conflicts with Codex IDE/CLI sessions.
PERSONAL_AGENT_CODEX_SUBSCRIPTION__CODEX_HOME=~/.personal-agent/codex-auth
PERSONAL_AGENT_CODEX_SUBSCRIPTION__TIMEOUT_SECONDS=120
PERSONAL_AGENT_CODEX_SUBSCRIPTION__WORKING_DIRECTORY=/tmp/personal-agent-codex
PERSONAL_AGENT_CODEX_SUBSCRIPTION__MAX_PROMPT_CHARS=80000
PERSONAL_AGENT_CODEX_SUBSCRIPTION__MAX_RESPONSE_BYTES=256000
PERSONAL_AGENT_CODEX_SUBSCRIPTION__MAX_STDERR_CHARS=2000
PERSONAL_AGENT_CODEX_SUBSCRIPTION__CORRECTIVE_RETRIES=1

PERSONAL_AGENT_TODOIST__ENABLED=false
PERSONAL_AGENT_TODOIST__API_TOKEN=

PERSONAL_AGENT_RESEARCH__ENABLED=true
PERSONAL_AGENT_RESEARCH__PROVIDERS='["duckduckgo"]'
PERSONAL_AGENT_RESEARCH__MAX_RESULTS=5
PERSONAL_AGENT_RESEARCH__REGION=us-en
PERSONAL_AGENT_RESEARCH__SAFE_SEARCH=moderate

PERSONAL_AGENT_TELEGRAM__ENABLED=false
PERSONAL_AGENT_TELEGRAM__BOT_TOKEN=
# Pydantic Settings expects JSON for list-valued environment variables.
PERSONAL_AGENT_TELEGRAM__ALLOWED_CHAT_IDS=[]

PERSONAL_AGENT_LOCAL_EXECUTION__ENABLED=false
PERSONAL_AGENT_LOCAL_EXECUTION__WORKSPACE_ROOT=~/agent-workspaces
PERSONAL_AGENT_LOCAL_EXECUTION__SANDBOX_BACKEND=docker
PERSONAL_AGENT_LOCAL_EXECUTION__DOCKER_IMAGE=personal-agent-sandbox:latest
PERSONAL_AGENT_LOCAL_EXECUTION__COMMAND_TIMEOUT_SECONDS=120
PERSONAL_AGENT_LOCAL_EXECUTION__MAX_OUTPUT_BYTES=1000000
PERSONAL_AGENT_LOCAL_EXECUTION__MEMORY_LIMIT=512m
PERSONAL_AGENT_LOCAL_EXECUTION__CPU_LIMIT=1.0
PERSONAL_AGENT_LOCAL_EXECUTION__PIDS_LIMIT=128
# JSON list of exact existing repository paths OpenCode may mount.
PERSONAL_AGENT_LOCAL_EXECUTION__REPOSITORY_PATHS=[]

PERSONAL_AGENT_OPENCODE__ENABLED=false
PERSONAL_AGENT_OPENCODE__EXECUTABLE=opencode
PERSONAL_AGENT_OPENCODE__MODEL=deepseek/deepseek-chat
PERSONAL_AGENT_OPENCODE__TIMEOUT_SECONDS=900
PERSONAL_AGENT_OPENCODE__MAX_DIFF_CHARS=20000
PERSONAL_AGENT_OPENCODE__MAX_REPORT_CHARS=8000
