# Rendered by install-systemd.sh. Keep the installed file root-owned with mode 0600.
PERSONAL_AGENT_ENVIRONMENT=production
PERSONAL_AGENT_DATABASE_URL=sqlite+aiosqlite:////var/lib/personal-agent/data/personal_agent.sqlite3
PERSONAL_AGENT_DATA_DIR=/var/lib/personal-agent/data
PERSONAL_AGENT_CHECKPOINT_PATH=/var/lib/personal-agent/data/checkpoints.sqlite3
PERSONAL_AGENT_POLICY_PATH=/opt/personal-agent/config/policy.example.yaml
PERSONAL_AGENT_LOG_LEVEL=WARNING
PERSONAL_AGENT_LOG_FORMAT=json
PERSONAL_AGENT_LOG_REDACTED_FIELDS=[]
PERSONAL_AGENT_POLICY__SESSION_TTL_MINUTES=120
PERSONAL_AGENT_POLICY__APPROVAL_TTL_MINUTES=15
PERSONAL_AGENT_CONVERSATION__MAX_TURNS=20
PERSONAL_AGENT_CONVERSATION__MAX_CONTEXT_CHARS=40000

# Configure at least one coordinator route before starting the service.
PERSONAL_AGENT_OPENAI__ENABLED=false
PERSONAL_AGENT_OPENAI__API_KEY=
PERSONAL_AGENT_DEEPSEEK__ENABLED=false
PERSONAL_AGENT_DEEPSEEK__API_KEY=
PERSONAL_AGENT_COORDINATOR__ENABLED=false
PERSONAL_AGENT_COORDINATOR__MODELS=[]

# Optional ChatGPT subscription coordinator owned by the dedicated service user.
PERSONAL_AGENT_CODEX_SUBSCRIPTION__ENABLED=false
PERSONAL_AGENT_CODEX_SUBSCRIPTION__EXECUTABLE=codex
PERSONAL_AGENT_CODEX_SUBSCRIPTION__MODEL=gpt-5.4
PERSONAL_AGENT_CODEX_SUBSCRIPTION__CODEX_HOME=/var/lib/personal-agent/codex-auth
PERSONAL_AGENT_CODEX_SUBSCRIPTION__WORKING_DIRECTORY=/var/lib/personal-agent/tmp/codex

PERSONAL_AGENT_TELEGRAM__ENABLED=true
PERSONAL_AGENT_TELEGRAM__BOT_TOKEN=
PERSONAL_AGENT_TELEGRAM__ALLOWED_CHAT_IDS=[]
PERSONAL_AGENT_TELEGRAM__ALLOWED_USER_IDS=[]
PERSONAL_AGENT_TELEGRAM__POLL_TIMEOUT_SECONDS=30
PERSONAL_AGENT_TELEGRAM__REQUEST_TIMEOUT_SECONDS=45
PERSONAL_AGENT_TELEGRAM__RETRY_DELAY_SECONDS=3

PERSONAL_AGENT_RESEARCH__ENABLED=true
PERSONAL_AGENT_RESEARCH__PROVIDERS='["duckduckgo"]'
PERSONAL_AGENT_RESEARCH__MAX_RESULTS=5

PERSONAL_AGENT_TODOIST__ENABLED=false
PERSONAL_AGENT_TODOIST__API_TOKEN=

PERSONAL_AGENT_LOCAL_EXECUTION__ENABLED=true
PERSONAL_AGENT_LOCAL_EXECUTION__WORKSPACE_ROOT=/var/lib/personal-agent/workspaces
PERSONAL_AGENT_LOCAL_EXECUTION__SANDBOX_BACKEND=docker
PERSONAL_AGENT_LOCAL_EXECUTION__DOCKER_IMAGE=personal-agent-sandbox:latest
PERSONAL_AGENT_LOCAL_EXECUTION__REPOSITORY_PATHS=[]
PERSONAL_AGENT_OPENCODE__ENABLED=false
PERSONAL_AGENT_OPENCODE__MODEL=deepseek/deepseek-chat
PERSONAL_AGENT_OPENCODE__MAX_LOG_CHARS=20000
PERSONAL_AGENT_OPENCODE__MAX_WORKER_EVENTS=100
PERSONAL_AGENT_OPENCODE__MAX_MANIFEST_FILES=10000
PERSONAL_AGENT_OPENCODE__MAX_MANIFEST_FILE_BYTES=10000000
PERSONAL_AGENT_OPENCODE__MAX_MANIFEST_TOTAL_BYTES=100000000
